# Copy this file to `.env` in the project root (never commit `.env`).

# Required (default LLM): Your OpenAI API key — create one at https://platform.openai.com
OPENAI_API_KEY=

# Optional: LLM vendor — openai (default) or anthropic
# LLM_PROVIDER=openai

# Optional: OpenAI model id for chat completions
# OPENAI_MODEL=gpt-4o-mini

# Optional: OpenAI sampling temperature (0–2)
# OPENAI_TEMPERATURE=0.72

# Optional: OpenAI max completion tokens per call
# OPENAI_MAX_TOKENS=1400

# Required when LLM_PROVIDER=anthropic: Your Anthropic API key
# ANTHROPIC_API_KEY=

# Optional: Anthropic model (claude-sonnet-4-20250514 recommended)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: Anthropic max tokens per response
# ANTHROPIC_MAX_TOKENS=4096

# Optional: Max tool-call steps per agent turn (built-ins + MCP)
# MAX_TOOL_STEPS=10

# Optional: Extra self-improvement pass per agent (0 = off, max 3)
# SELF_IMPROVE_MAX_ROUNDS=1

# Optional: MCP stdio servers as JSON array (local / long-running Node only — not supported on Vercel)
# MCP_SERVERS=[{"id":"my-server","command":"npx","args":["-y","my-mcp-package"]}]

# Optional: Port for local API (`npm run server`)
# PORT=3001

# Optional: Allow server to start without keys; `/api/health` will still report ai:false (debugging only)
# STORYOS_SKIP_ENV_CHECK=1

# Optional: Comma-separated browser origins for CORS when API and UI are on different domains
# CORS_ORIGIN=https://your-app.vercel.app

# Optional: API base URL for the built UI when static files call a remote API (no trailing slash)
# VITE_API_BASE_URL=https://api.example.com

# Optional: Print StoryOS debug logs from the server (console)
# DEBUG=true

# --- AgentOS integration (optional) ---
# Optional: UI badge “AgentOS” in the live panel (must start with VITE_ for Vite)
# VITE_MODE=agentOS

# Optional: Server mode — with AGENTOS_WEBHOOK_URL, POSTs each completed panel round for human approval
# STORYOS_MODE=agentOS

# Optional: HTTPS URL of your approval queue / AgentOS ingest endpoint
# AGENTOS_WEBHOOK_URL=https://your-agentos.example.com/api/storyos/ingest

# Optional: Shared secret sent as header X-StoryOS-Secret (your receiver should validate)
# AGENTOS_WEBHOOK_SECRET=
