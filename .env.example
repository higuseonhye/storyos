# StoryOS API — copy to .env in the project root (never commit .env)

# --- Provider (escape single-vendor lock-in) ---
# openai | anthropic
LLM_PROVIDER=openai

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Optional: Anthropic instead of OpenAI
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_MAX_TOKENS=4096

# Optional tuning (OpenAI path)
# OPENAI_TEMPERATURE=0.72
# OPENAI_MAX_TOKENS=1400

# Tool loop & bounded "self-improvement" (extra model pass per agent, max 3)
# MAX_TOOL_STEPS=10
# SELF_IMPROVE_MAX_ROUNDS=0

# --- MCP: attach stdio servers (JSON array). Tools appear as mcp__<id>__<tool> ---
# Example filesystem server (paths are server-side only — lock down carefully):
# MCP_SERVERS=[{"id":"fs","command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","."]}]

# API server
PORT=3001

# Comma-separated origins for browser clients (production). Omit for permissive dev.
# CORS_ORIGIN=https://your-app.vercel.app

# Frontend production build — base URL of the API (no trailing slash)
# VITE_API_BASE_URL=https://api.yourdomain.com
